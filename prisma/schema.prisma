generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ServiceCategory {
  id                        Int                      @id @default(autoincrement())
  name                      String                   @db.VarChar(100)
  slug                      String                   @unique @db.VarChar(120)
  description               String?                  @db.Text
  icon                      String?                  @db.VarChar(50)
  image_url                 String?                  @db.VarChar(500)
  is_active                 Boolean                  @default(true)
  sort_order                Int                      @default(0)
  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @updatedAt
  manufacturer_capabilities ManufacturerCapability[]
  rfq_projects              RfqProject[]

  @@map("service_categories")
}

model Company {
  id                            Int                         @id @default(autoincrement())
  name                          String                      @db.VarChar(200)
  slug                          String                      @unique @db.VarChar(220)
  type                          CompanyType
  legal_id                      String?                     @db.VarChar(50)
  description                   String?                     @db.Text
  logo_url                      String?                     @db.MediumText
  website                       String?                     @db.VarChar(500)
  phone                         String?                     @db.VarChar(50)
  email                         String?                     @db.VarChar(255)
  address_line1                 String?                     @db.VarChar(255)
  city                          String?                     @db.VarChar(100)
  state                         String?                     @db.VarChar(100)
  country                       String                      @default("Colombia") @db.VarChar(100)
  latitude                      Decimal?                    @db.Decimal(10, 8)
  longitude                     Decimal?                    @db.Decimal(11, 8)
  employee_count                String?                     @db.VarChar(10)
  founded_year                  Int?                        @db.SmallInt
  is_verified                   Boolean                     @default(false)
  is_active                     Boolean                     @default(true)
  verified_at                   DateTime?
  created_at                    DateTime                    @default(now())
  updated_at                    DateTime                    @updatedAt
  brand_categories              String?                     @db.Text
  brand_tagline                 String?                     @db.VarChar(160)
  cover_image_url               String?                     @db.MediumText
  instagram_handle              String?                     @db.VarChar(120)
  ships_worldwide               Boolean                     @default(false)
  contracts_as_brand            Contract[]                  @relation("ContractBrand")
  contracts_as_manufacturer     Contract[]                  @relation("ContractManufacturer")
  conversations_as_brand        Conversation[]              @relation("ConvBrand")
  conversations_as_manufacturer Conversation[]              @relation("ConvManufacturer")
  conversations_as_admin_target Conversation[]              @relation("ConvAdminTarget")
  manufacturer_capabilities     ManufacturerCapability[]
  manufacturer_certifications   ManufacturerCertification[]
  payments_as_payee             Payment[]                   @relation("Payee")
  payments_as_payer             Payment[]                   @relation("Payer")
  proposals_as_manufacturer     Proposal[]                  @relation("ManufacturerCompany")
  reviews_received              Review[]                    @relation("ReviewedCompany")
  reviews_given                 Review[]                    @relation("ReviewerCompany")
  rfq_projects_as_brand         RfqProject[]                @relation("BrandCompany")
  design_projects_as_brand      DesignProject[]             @relation("DesignProjectBrand")
  design_projects_as_manufacturer DesignProject[]           @relation("DesignProjectManufacturer")
  users                         User[]
  designer_profiles              DesignerProfile[]

  @@map("companies")
}

model User {
  id                         Int                     @id @default(autoincrement())
  email                      String                  @unique @db.VarChar(255)
  password                   String                  @db.VarChar(255)
  first_name                 String                  @db.VarChar(100)
  last_name                  String                  @db.VarChar(100)
  phone                      String?                 @db.VarChar(50)
  avatar_url                 String?                 @db.MediumText
  preferred_currency         String                  @default("USD") @db.VarChar(3)
  role                       users_role              @default(brand)
  company_id                 Int?
  terms_accepted             Boolean                 @default(false)
  email_verified             Boolean                 @default(false)
  email_verified_at          DateTime?
  google_id                  String?                 @unique @db.VarChar(255)
  auth_provider              String                  @default("local") @db.VarChar(20)
  email_verification_token   String?                 @db.VarChar(255)
  email_verification_expires DateTime?               @db.DateTime(0)
  stripe_customer_id         String?                 @unique(map: "stripe_customer_id") @db.VarChar(255)
  is_active                  Boolean                 @default(true)
  created_at                 DateTime                @default(now())
  updated_at                 DateTime                @updatedAt
  addresses                  Address[]
  admin_notes                AdminNote[]             @relation("AdminNotes")
  admin_conversations        Conversation[]          @relation("ConversationAdmin")
  initiated_conversations    Conversation[]          @relation("ConversationInitiator")
  messages                   Message[]
  notifications              Notification[]
  password_reset_tokens      password_reset_tokens[]
  proposals                  Proposal[]
  reviews                    Review[]
  rfq_projects               RfqProject[]
  design_projects            DesignProject[]
  design_likes               DesignLike[]
  strategy_call_purchases    StrategyCallPurchase[]
  subscriptions              Subscription[]
  support_chats_admin        SupportChat[]           @relation("SupportChatAdmin")
  support_chats_initiated    SupportChat[]           @relation("SupportChatInitiator")
  support_messages           SupportMessage[]
  payment_methods            UserPaymentMethod[]
  company                    Company?                @relation(fields: [company_id], references: [id])
  designer_profile           DesignerProfile?

  @@index([company_id], map: "idx_users_company")
  @@index([stripe_customer_id], map: "idx_users_stripe")
  @@index([email_verification_token], map: "idx_verification_token")
  @@map("users")
}

model Address {
  id            Int      @id @default(autoincrement())
  user_id       Int
  label         String   @default("Oficina") @db.VarChar(100)
  address_line1 String   @db.VarChar(255)
  address_line2 String?  @db.VarChar(255)
  city          String   @db.VarChar(100)
  state         String?  @db.VarChar(100)
  postal_code   String?  @db.VarChar(20)
  country       String   @default("Colombia") @db.VarChar(100)
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_user_id")
  @@map("addresses")
}

model ManufacturerCapability {
  id                   Int             @id @default(autoincrement())
  company_id           Int
  category_id          Int
  min_order_qty        Int             @default(1)
  max_monthly_capacity Int?
  lead_time_days       Int?
  description          String?         @db.Text
  is_active            Boolean         @default(true)
  created_at           DateTime        @default(now())
  category             ServiceCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  company              Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, category_id])
  @@index([company_id], map: "idx_company")
  @@index([category_id], map: "manufacturer_capabilities_category_id_fkey")
  @@map("manufacturer_capabilities")
}

model ManufacturerCertification {
  id              Int       @id @default(autoincrement())
  company_id      Int
  name            String    @db.VarChar(100)
  issued_by       String?   @db.VarChar(200)
  certificate_url String?   @db.MediumText
  issued_at       DateTime? @db.Date
  expires_at      DateTime? @db.Date
  is_verified     Boolean   @default(false)
  created_at      DateTime  @default(now())
  company         Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id], map: "idx_company")
  @@map("manufacturer_certifications")
}

model RfqProject {
  id                      Int             @id @default(autoincrement())
  code                    String          @unique @db.VarChar(20)
  project_type            String?         @db.VarChar(50)
  brand_company_id        Int
  created_by_user_id      Int
  created_by_admin_id     Int?
  category_id             Int
  title                   String          @db.VarChar(255)
  description             String          @db.Text
  quantity                Int
  budget_min              Decimal?        @db.Decimal(12, 2)
  budget_max              Decimal?        @db.Decimal(12, 2)
  currency                String          @default("COP") @db.VarChar(3)
  deadline                DateTime?       @db.Date
  proposals_deadline      DateTime?       @db.Date
  status                  RfqStatus       @default(draft)
  requires_sample         Boolean         @default(false)
  preferred_materials     String?         @db.Text
  sustainability_priority Boolean         @default(false)
  proposals_count         Int             @default(0)
  awarded_proposal_id     Int?
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt
  contracts               Contract[]
  conversations           Conversation[]
  proposals               Proposal[]      @relation("RfqProposals")
  rfq_attachments         RfqAttachment[]
  rfq_materials           RfqMaterial[]
  awarded_proposal        Proposal?       @relation("AwardedProposal", fields: [awarded_proposal_id], references: [id])
  brand_company           Company         @relation("BrandCompany", fields: [brand_company_id], references: [id])
  category                ServiceCategory @relation(fields: [category_id], references: [id])
  created_by              User            @relation(fields: [created_by_user_id], references: [id])

  @@index([brand_company_id], map: "idx_brand")
  @@index([category_id], map: "idx_category")
  @@index([awarded_proposal_id], map: "rfq_projects_awarded_proposal_id_fkey")
  @@index([created_by_user_id], map: "rfq_projects_created_by_user_id_fkey")
  @@map("rfq_projects")
}

model RfqMaterial {
  id                  Int        @id @default(autoincrement())
  rfq_id              Int
  material_type       String     @db.VarChar(100)
  composition         String?    @db.VarChar(255)
  recycled_percentage Int        @default(0) @db.TinyInt
  specifications      String?    @db.Text
  created_at          DateTime   @default(now())
  rfq_project         RfqProject @relation(fields: [rfq_id], references: [id], onDelete: Cascade)

  @@index([rfq_id], map: "idx_rfq")
  @@map("rfq_materials")
}

model RfqAttachment {
  id          Int        @id @default(autoincrement())
  rfq_id      Int
  file_name   String     @db.VarChar(255)
  file_url    String     @db.VarChar(500)
  file_type   String?    @db.VarChar(50)
  file_size   Int?
  created_at  DateTime   @default(now())
  rfq_project RfqProject @relation(fields: [rfq_id], references: [id], onDelete: Cascade)

  @@index([rfq_id], map: "idx_rfq")
  @@map("rfq_attachments")
}

model Proposal {
  id                      Int            @id @default(autoincrement())
  rfq_id                  Int
  manufacturer_company_id Int
  submitted_by_user_id    Int
  unit_price              Decimal        @db.Decimal(12, 2)
  total_price             Decimal        @db.Decimal(12, 2)
  currency                String         @default("COP") @db.VarChar(3)
  lead_time_days          Int
  proposed_materials      String?        @db.Text
  recycled_percentage     Int            @default(0) @db.TinyInt
  notes                   String?        @db.Text
  status                  ProposalStatus @default(submitted)
  green_score             Decimal        @default(0.00) @db.Decimal(5, 2)
  distance_km             Decimal?       @db.Decimal(8, 2)
  submitted_at            DateTime       @default(now())
  responded_at            DateTime?
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  contracts               Contract[]
  manufacturer_company    Company        @relation("ManufacturerCompany", fields: [manufacturer_company_id], references: [id])
  rfq_project             RfqProject     @relation("RfqProposals", fields: [rfq_id], references: [id], onDelete: Cascade)
  submitted_by            User           @relation(fields: [submitted_by_user_id], references: [id])
  awarded_rfq_projects    RfqProject[]   @relation("AwardedProposal")

  @@unique([rfq_id, manufacturer_company_id])
  @@index([manufacturer_company_id], map: "idx_manufacturer")
  @@index([rfq_id], map: "idx_rfq")
  @@index([submitted_by_user_id], map: "proposals_submitted_by_user_id_fkey")
  @@map("proposals")
}

model Contract {
  id                      Int                 @id @default(autoincrement())
  code                    String              @unique @db.VarChar(20)
  rfq_id                  Int
  proposal_id             Int?
  design_project_id       Int?
  brand_company_id        Int
  manufacturer_company_id Int
  total_amount            Decimal             @db.Decimal(12, 2)
  currency                String              @default("COP") @db.VarChar(3)
  status                  ContractStatus      @default(active)
  terms                   String?             @db.Text
  start_date              DateTime?           @db.Date
  expected_end_date       DateTime?           @db.Date
  actual_end_date         DateTime?           @db.Date
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt
  milestones              ContractMilestone[]
  brand_company           Company             @relation("ContractBrand", fields: [brand_company_id], references: [id])
  design_project          DesignProject?      @relation(fields: [design_project_id], references: [id])
  manufacturer_company    Company             @relation("ContractManufacturer", fields: [manufacturer_company_id], references: [id])
  proposal                Proposal?           @relation(fields: [proposal_id], references: [id], onDelete: Restrict)
  rfq_project             RfqProject          @relation(fields: [rfq_id], references: [id])
  conversations           Conversation[]
  payments                Payment[]
  reviews                 Review[]

  @@index([proposal_id], map: "contracts_proposal_id_fkey")
  @@index([rfq_id], map: "contracts_rfq_id_fkey")
  @@index([brand_company_id], map: "idx_brand")
  @@index([manufacturer_company_id], map: "idx_manufacturer")
  @@index([design_project_id], map: "idx_contract_design_project")
  @@map("contracts")
}

model ContractMilestone {
  id             Int                    @id @default(autoincrement())
  contract_id    Int
  title          String                 @db.VarChar(200)
  description    String?                @db.Text
  sort_order     Int                    @default(0) @db.TinyInt
  status         MilestoneStatus        @default(pending)
  payment_amount Decimal                @default(0.00) @db.Decimal(12, 2)
  payment_status MilestonePaymentStatus @default(pending)
  due_date       DateTime?              @db.Date
  completed_at   DateTime?
  created_at     DateTime               @default(now())
  contract       Contract               @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([contract_id], map: "idx_contract")
  @@map("contract_milestones")
}

model Conversation {
  id                      Int                @id @default(autoincrement())
  rfq_id                  Int?
  contract_id             Int?
  design_project_id       Int?
  brand_company_id        Int?
  manufacturer_company_id Int?
  designer_profile_id     Int?
  target_company_id       Int?
  admin_user_id           Int?
  initiated_by_user_id    Int
  subject                 String?            @db.VarChar(255)
  status                  ConversationStatus @default(pending)
  last_message_at         DateTime?
  accepted_at             DateTime?
  created_at              DateTime           @default(now())
  admin_user              User?              @relation("ConversationAdmin", fields: [admin_user_id], references: [id], onDelete: Cascade)
  brand_company           Company?           @relation("ConvBrand", fields: [brand_company_id], references: [id], onDelete: Cascade)
  contract                Contract?          @relation(fields: [contract_id], references: [id])
  design_project          DesignProject?     @relation(fields: [design_project_id], references: [id])
  designer_profile        DesignerProfile?   @relation(fields: [designer_profile_id], references: [id])
  initiated_by            User               @relation("ConversationInitiator", fields: [initiated_by_user_id], references: [id], onDelete: Cascade)
  manufacturer_company    Company?           @relation("ConvManufacturer", fields: [manufacturer_company_id], references: [id], onDelete: Cascade)
  rfq_project             RfqProject?        @relation(fields: [rfq_id], references: [id])
  target_company          Company?           @relation("ConvAdminTarget", fields: [target_company_id], references: [id], onDelete: Cascade)
  messages                Message[]

  @@index([contract_id], map: "conversations_contract_id_fkey")
  @@index([initiated_by_user_id], map: "conversations_initiated_by_user_id_fkey")
  @@index([admin_user_id], map: "idx_admin_user")
  @@index([brand_company_id], map: "idx_brand")
  @@index([manufacturer_company_id], map: "idx_manufacturer")
  @@index([rfq_id], map: "idx_rfq")
  @@index([design_project_id], map: "idx_conv_design_project")
  @@index([designer_profile_id], map: "idx_conv_designer")
  @@index([target_company_id], map: "idx_target_company")
  @@map("conversations")
}

model Message {
  id              Int          @id @default(autoincrement())
  conversation_id Int
  sender_user_id  Int
  content         String       @db.Text
  message_type    MessageType  @default(text)
  file_url        String?      @db.VarChar(500)
  metadata        Json?
  is_read         Boolean      @default(false)
  read_at         DateTime?
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [sender_user_id], references: [id], onDelete: Cascade)

  @@index([conversation_id], map: "idx_conversation")
  @@index([sender_user_id], map: "messages_sender_user_id_fkey")
  @@map("messages")
}

model SupportChat {
  id                   Int               @id @default(autoincrement())
  initiated_by_user_id Int
  admin_user_id        Int?
  subject              String            @db.VarChar(255)
  message              String            @db.Text
  status               SupportChatStatus @default(pending)
  accepted_at          DateTime?
  closed_at            DateTime?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  admin_user           User?             @relation("SupportChatAdmin", fields: [admin_user_id], references: [id], onDelete: Cascade)
  initiated_by         User              @relation("SupportChatInitiator", fields: [initiated_by_user_id], references: [id], onDelete: Cascade)
  support_messages     SupportMessage[]

  @@index([status], map: "idx_status")
  @@index([admin_user_id], map: "idx_admin_user")
  @@index([initiated_by_user_id], map: "idx_initiated_by")
  @@map("support_chats")
}

model SupportMessage {
  id              Int         @id @default(autoincrement())
  support_chat_id Int
  sender_user_id  Int
  content         String      @db.Text
  created_at      DateTime    @default(now())
  sender          User        @relation(fields: [sender_user_id], references: [id], onDelete: Cascade)
  support_chat    SupportChat @relation(fields: [support_chat_id], references: [id], onDelete: Cascade)

  @@index([support_chat_id], map: "idx_support_chat")
  @@index([sender_user_id], map: "idx_sender")
  @@map("support_messages")
}

model Review {
  id                  Int      @id @default(autoincrement())
  contract_id         Int
  reviewer_company_id Int
  reviewed_company_id Int
  reviewer_user_id    Int
  rating              Int      @db.TinyInt
  comment             String?  @db.Text
  is_public           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  contract            Contract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  reviewed_company    Company  @relation("ReviewedCompany", fields: [reviewed_company_id], references: [id], onDelete: Cascade)
  reviewer_company    Company  @relation("ReviewerCompany", fields: [reviewer_company_id], references: [id], onDelete: Cascade)
  reviewer_user       User     @relation(fields: [reviewer_user_id], references: [id], onDelete: Cascade)

  @@unique([contract_id, reviewer_company_id])
  @@index([reviewed_company_id], map: "idx_reviewed")
  @@index([reviewer_company_id], map: "reviews_reviewer_company_id_fkey")
  @@index([reviewer_user_id], map: "reviews_reviewer_user_id_fkey")
  @@map("reviews")
}

model Payment {
  id               Int                @id @default(autoincrement())
  contract_id      Int
  milestone_id     Int?
  payer_company_id Int
  payee_company_id Int
  amount           Decimal            @db.Decimal(12, 2)
  currency         String             @default("COP") @db.VarChar(3)
  payment_method   PaymentMethod      @default(transfer)
  status           PaymentStatus      @default(pending)
  transaction_id   String?            @db.VarChar(255)
  payment_gateway  String?            @db.VarChar(50)
  paid_at          DateTime?
  refunded_at      DateTime?
  metadata         Json?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  contract         Contract           @relation(fields: [contract_id], references: [id])
  milestone        ContractMilestone? @relation(fields: [milestone_id], references: [id])
  payee_company    Company            @relation("Payee", fields: [payee_company_id], references: [id])
  payer_company    Company            @relation("Payer", fields: [payer_company_id], references: [id])

  @@index([contract_id], map: "idx_contract")
  @@index([payee_company_id], map: "idx_payee")
  @@index([payer_company_id], map: "idx_payer")
  @@index([milestone_id], map: "payments_milestone_id_fkey")
  @@map("payments")
}

model Invoice {
  id                       Int           @id @default(autoincrement())
  code                     String        @unique @db.VarChar(20)
  contract_id              Int
  conversation_id          Int?
  production_cost          Decimal       @db.Decimal(10, 2)
  shipping_cost            Decimal       @default(0.00) @db.Decimal(10, 2)
  other_costs              Decimal       @default(0.00) @db.Decimal(10, 2)
  subtotal                 Decimal       @db.Decimal(10, 2)
  tax_rate                 Decimal       @default(0.00) @db.Decimal(5, 2)
  tax_amount               Decimal       @default(0.00) @db.Decimal(10, 2)
  platform_fee_rate        Decimal       @default(3.00) @db.Decimal(5, 2)
  platform_fee             Decimal       @default(0.00) @db.Decimal(10, 2)
  total                    Decimal       @db.Decimal(10, 2)
  currency                 String        @default("EUR") @db.VarChar(3)
  status                   InvoiceStatus @default(draft)
  proposed_by              Int
  notes                    String?       @db.Text
  paid_at                  DateTime?     @db.DateTime(0)
  stripe_payment_intent_id String?       @db.VarChar(255)
  created_at               DateTime      @default(now()) @db.DateTime(0)
  updated_at               DateTime      @default(now()) @updatedAt @db.DateTime(0)

  @@index([contract_id], map: "idx_invoice_contract")
  @@index([conversation_id], map: "idx_invoice_conversation")
  @@index([status], map: "idx_invoice_status")
  @@map("invoices")
}

model Notification {
  id             Int              @id @default(autoincrement())
  user_id        Int
  title          String           @db.VarChar(255)
  message        String           @db.Text
  type           NotificationType
  reference_type String?          @db.VarChar(50)
  reference_id   Int?
  is_read        Boolean          @default(false)
  read_at        DateTime?
  created_at     DateTime         @default(now())
  user           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "notifications_user_id_fkey")
  @@map("notifications")
}

model AdminNote {
  id          Int       @id @default(autoincrement())
  entity_type String    @db.VarChar(50)
  entity_id   Int
  admin_id    Int
  content     String    @db.Text
  created_at  DateTime? @default(now()) @db.DateTime(0)
  admin       User      @relation("AdminNotes", fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_admin_notes_user")

  @@index([entity_type, entity_id], map: "idx_entity")
  @@index([admin_id], map: "idx_admin")
  @@map("admin_notes")
}

model I18nKey {
  id          Int      @id @default(autoincrement())
  key_path    String   @unique(map: "key_path") @db.VarChar(255)
  module      String   @db.VarChar(100)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([module], map: "idx_i18n_keys_module")
  @@index([is_active], map: "idx_i18n_keys_active")
  @@map("i18n_keys")
}

model I18nValue {
  id                   Int       @id @default(autoincrement())
  key_id               Int
  locale               String    @db.VarChar(5)
  value_text           String    @db.MediumText
  status               String    @db.VarChar(20)
  version              Int       @default(1)
  created_by_user_id   Int
  published_by_user_id Int?
  published_at         DateTime? @db.DateTime(0)
  created_at           DateTime  @default(now()) @db.DateTime(0)
  updated_at           DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@unique([key_id, locale, version], map: "uq_i18n_values_key_locale_version")
  @@index([key_id, locale], map: "idx_i18n_values_key_locale")
  @@index([locale, status], map: "idx_i18n_values_locale_status")
  @@map("i18n_values")
}

model I18nAuditLog {
  id                 Int      @id @default(autoincrement())
  key_path           String   @db.VarChar(255)
  locale             String   @db.VarChar(5)
  old_value          String?  @db.MediumText
  new_value          String   @db.MediumText
  action             String   @db.VarChar(20)
  changed_by_user_id Int
  created_at         DateTime @default(now()) @db.DateTime(0)

  @@index([key_path, locale], map: "idx_i18n_audit_key_locale")
  @@index([created_at], map: "idx_i18n_audit_created")
  @@map("i18n_audit_logs")
}

model SubscriptionPlan {
  id                  Int                            @id @default(autoincrement())
  slug                SubscriptionPlanType           @unique
  name                String                         @db.VarChar(100)
  target_role         subscription_plans_target_role
  price_usd           Decimal                        @db.Decimal(8, 2)
  max_active_projects Int                            @default(-1)
  priority_matching   Boolean                        @default(false)
  verified_badge      Boolean                        @default(false)
  production_tracking Boolean                        @default(false)
  dedicated_support   Boolean                        @default(false)
  stripe_price_id     String?                        @db.VarChar(255)
  is_active           Boolean                        @default(true)
  created_at          DateTime                       @default(now())
  updated_at          DateTime                       @updatedAt
  subscriptions       Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                     Int                   @id @default(autoincrement())
  user_id                Int
  plan_id                Int
  status                 SubscriptionStatus    @default(trial)
  stripe_subscription_id String?               @unique(map: "stripe_subscription_id") @db.VarChar(255)
  trial_ends_at          DateTime?
  current_period_start   DateTime
  current_period_end     DateTime
  cancelled_at           DateTime?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  invoices               SubscriptionInvoice[]
  plan                   SubscriptionPlan      @relation(fields: [plan_id], references: [id])
  user                   User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([stripe_subscription_id], map: "idx_subscriptions_stripe")
  @@index([plan_id], map: "subscriptions_plan_id_fkey")
  @@index([user_id], map: "subscriptions_user_id_fkey")
  @@map("subscriptions")
}

model SubscriptionInvoice {
  id                Int           @id @default(autoincrement())
  subscription_id   Int
  stripe_invoice_id String?       @db.VarChar(255)
  amount            Decimal       @db.Decimal(8, 2)
  currency          String        @default("USD") @db.VarChar(3)
  status            PaymentStatus @default(pending)
  description       String?       @db.VarChar(255)
  paid_at           DateTime?
  created_at        DateTime      @default(now())
  subscription      Subscription  @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([stripe_invoice_id], map: "idx_invoices_stripe")
  @@index([subscription_id], map: "subscription_invoices_subscription_id_fkey")
  @@map("subscription_invoices")
}

model UserPaymentMethod {
  id                       Int       @id @default(autoincrement())
  user_id                  Int
  stripe_payment_method_id String?   @db.VarChar(255)
  type                     String    @db.VarChar(20)
  last_four                String    @db.VarChar(4)
  brand                    String?   @db.VarChar(20)
  is_default               Boolean   @default(false)
  expires_at               DateTime? @db.Date
  created_at               DateTime  @default(now())
  user                     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "user_payment_methods_user_id_fkey")
  @@map("user_payment_methods")
}

model StrategyCallPurchase {
  id                Int                        @id @default(autoincrement())
  user_id           Int
  stripe_session_id String                     @unique @db.VarChar(255)
  status            StrategyCallPurchaseStatus @default(pending)
  amount_usd        Decimal                    @default(150.00) @db.Decimal(10, 2)
  created_at        DateTime                   @default(now())
  updated_at        DateTime                   @default(now()) @updatedAt
  user              User                       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_scp_user")
  @@map("strategy_call_purchases")
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String    @unique(map: "token") @db.VarChar(255)
  expires_at DateTime  @db.DateTime(0)
  used_at    DateTime? @db.DateTime(0)
  created_at DateTime? @default(now())
  users      User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "password_reset_tokens_ibfk_1")

  @@index([token], map: "idx_reset_token")
  @@index([user_id], map: "idx_reset_user")
}

model chat_appeals {
  id              Int                 @id @default(autoincrement())
  user_id         Int
  conversation_id Int
  appeal_text     String              @db.Text
  status          chat_appeals_status @default(pending)
  admin_user_id   Int?
  resolved_at     DateTime?           @db.Timestamp(0)
  created_at      DateTime?           @default(now()) @db.Timestamp(0)

  @@index([status], map: "idx_status")
  @@index([user_id, conversation_id], map: "idx_user_conv")
}

model chat_blocks {
  id              Int       @id @default(autoincrement())
  user_id         Int
  conversation_id Int
  blocked_at      DateTime? @default(now()) @db.Timestamp(0)

  @@unique([user_id, conversation_id], map: "uk_user_conv")
}

model chat_violations {
  id              Int       @id @default(autoincrement())
  user_id         Int
  conversation_id Int
  violation_type  String    @default("contact_info") @db.VarChar(20)
  blocked_content String?   @db.Text
  created_at      DateTime? @default(now()) @db.Timestamp(0)

  @@index([user_id, conversation_id], map: "idx_user_conv")
}

