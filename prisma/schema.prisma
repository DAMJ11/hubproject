model DesignerProfile {
  id                  Int      @id @default(autoincrement())
  user_id             Int      @unique
  company_id          Int?
  display_name        String   @db.VarChar(200)
  slug                String?  @unique @db.VarChar(200)
  bio                 String?  @db.Text
  specialties         String?  @db.Text
  years_experience    Int?
  portfolio_url       String?  @db.VarChar(500)
  instagram_handle    String?  @db.VarChar(120)
  behance_url         String?  @db.VarChar(500)
  dribbble_url        String?  @db.VarChar(500)
  linkedin_url        String?  @db.VarChar(500)
  website_url         String?  @db.VarChar(500)
  location_city       String?  @db.VarChar(100)
  location_country    String   @default("Colombia") @db.VarChar(100)
  availability_status String   @default("available") @db.VarChar(20)
  hourly_rate_min     Decimal? @db.Decimal(10, 2)
  hourly_rate_max     Decimal? @db.Decimal(10, 2)
  currency            String   @default("USD") @db.VarChar(3)
  is_verified         Boolean  @default(false)
  rating_avg          Decimal  @default(0) @db.Decimal(3, 2)
  total_reviews       Int      @default(0)
  projects_completed  Int      @default(0)
  is_freelance        Boolean  @default(true)
  avatar_url          String?  @db.MediumText
  cover_image_url     String?  @db.MediumText
  stripe_connect_id   String?  @db.VarChar(255)
  stripe_onboarded    Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user            User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  company         Company?                @relation(fields: [company_id], references: [id])
  portfolio_items DesignerPortfolioItem[]
  design_proposals DesignProposal[]
  assigned_projects DesignProject[]       @relation("AssignedDesigner")
  payouts          DesignerPayout[]
  conversations    Conversation[]

  @@index([company_id], map: "idx_designer_company")
  @@index([slug], map: "idx_designer_slug")
  @@index([availability_status], map: "idx_designer_availability")
  @@index([location_country], map: "idx_designer_location")
  @@map("designer_profiles")
}

model DesignerPortfolioItem {
  id                   Int      @id @default(autoincrement())
  designer_profile_id  Int
  title                String   @db.VarChar(255)
  description          String?  @db.Text
  category             String   @db.VarChar(50)
  season               String?  @db.VarChar(30)
  year                 Int?
  image_url            String?  @db.MediumText
  tags                 String?  @db.Text
  is_public            Boolean  @default(true)
  views_count          Int      @default(0)
  likes_count          Int      @default(0)
  sort_order           Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  designer_profile DesignerProfile @relation(fields: [designer_profile_id], references: [id], onDelete: Cascade)
  likes            DesignLike[]

  @@index([designer_profile_id], map: "idx_portfolio_designer")
  @@index([category], map: "idx_portfolio_category")
  @@index([is_public], map: "idx_portfolio_public")
  @@map("designer_portfolio_items")
}

model DesignProject {
  id                   Int                 @id @default(autoincrement())
  code                 String              @unique @db.VarChar(20)
  brand_company_id     Int
  created_by_user_id   Int
  designer_profile_id  Int?
  category             String              @db.VarChar(50)
  title                String              @db.VarChar(255)
  description          String              @db.Text
  reference_images     String?             @db.Text
  season               String?             @db.VarChar(30)
  budget_min           Decimal?            @db.Decimal(12, 2)
  budget_max           Decimal?            @db.Decimal(12, 2)
  currency             String              @default("USD") @db.VarChar(3)
  deadline             DateTime?           @db.Date
  proposals_deadline   DateTime?           @db.Date
  status               DesignProjectStatus @default(draft)
  manufacturer_id      Int?
  proposals_count      Int                 @default(0)
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  brand_company    Company          @relation("DesignProjectBrand", fields: [brand_company_id], references: [id])
  created_by       User             @relation(fields: [created_by_user_id], references: [id])
  designer_profile DesignerProfile? @relation("AssignedDesigner", fields: [designer_profile_id], references: [id])
  manufacturer     Company?         @relation("DesignProjectManufacturer", fields: [manufacturer_id], references: [id])
  proposals        DesignProposal[]
  payouts          DesignerPayout[]
  conversations    Conversation[]
  contracts        Contract[]

  @@index([brand_company_id], map: "idx_dp_brand")
  @@index([designer_profile_id], map: "idx_dp_designer")
  @@index([status], map: "idx_dp_status")
  @@index([created_by_user_id], map: "idx_dp_created_by")
  @@map("design_projects")
}

model DesignProposal {
  id                   Int                  @id @default(autoincrement())
  design_project_id    Int
  designer_profile_id  Int
  price                Decimal              @db.Decimal(12, 2)
  estimated_days       Int
  concept_notes        String?              @db.Text
  sample_attachments   String?              @db.Text
  status               DesignProposalStatus @default(submitted)
  submitted_at         DateTime             @default(now())
  responded_at         DateTime?

  design_project   DesignProject   @relation(fields: [design_project_id], references: [id], onDelete: Cascade)
  designer_profile DesignerProfile @relation(fields: [designer_profile_id], references: [id], onDelete: Cascade)

  @@unique([design_project_id, designer_profile_id], map: "idx_dp_unique_proposal")
  @@index([designer_profile_id], map: "idx_dpr_designer")
  @@index([status], map: "idx_dpr_status")
  @@map("design_proposals")
}

model DesignLike {
  id                      Int      @id @default(autoincrement())
  user_id                 Int
  designer_portfolio_item_id Int
  created_at              DateTime @default(now())

  user           User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  portfolio_item DesignerPortfolioItem @relation(fields: [designer_portfolio_item_id], references: [id], onDelete: Cascade)

  @@unique([user_id, designer_portfolio_item_id], map: "idx_design_like_unique")
  @@index([designer_portfolio_item_id], map: "idx_design_like_item")
  @@map("design_likes")
}

model DesignerPayout {
  id                   Int      @id @default(autoincrement())
  designer_profile_id  Int
  design_project_id    Int
  amount               Decimal  @db.Decimal(12, 2)
  currency             String   @default("USD") @db.VarChar(3)
  platform_fee         Decimal  @default(0) @db.Decimal(12, 2)
  net_amount           Decimal  @db.Decimal(12, 2)
  stripe_transfer_id   String?  @db.VarChar(255)
  status               String   @default("pending") @db.VarChar(20)
  paid_at              DateTime?
  created_at           DateTime @default(now())

  designer_profile DesignerProfile @relation(fields: [designer_profile_id], references: [id])
  design_project   DesignProject   @relation(fields: [design_project_id], references: [id])

  @@index([designer_profile_id], map: "idx_payout_designer")
  @@index([design_project_id], map: "idx_payout_project")
  @@map("designer_payouts")
}
