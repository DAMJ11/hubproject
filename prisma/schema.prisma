// Prisma schema for MySQL - HubProject
// Generado desde database/schema.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================
// Enums
// =============================================

enum CompanyType {
  brand
  manufacturer
}

enum UserRole {
  brand
  manufacturer
  admin
}

enum RfqStatus {
  draft
  open
  evaluating
  awarded
  cancelled
  expired
}

enum ProposalStatus {
  submitted
  shortlisted
  accepted
  rejected
  withdrawn
}

enum ContractStatus {
  active
  in_production
  completed
  disputed
  cancelled
}

enum MilestoneStatus {
  pending
  in_progress
  completed
  skipped
}

enum MilestonePaymentStatus {
  pending
  paid
  na
}

enum ConversationStatus {
  pending
  open
  closed
  archived
}

enum MessageType {
  text
  image
  file
  system
}

enum PaymentMethod {
  transfer
  card
  nequi
  daviplata
  other
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum NotificationType {
  message
  payment
  review
  system
  rfq
  proposal
  contract
}

// =============================================
// Models
// =============================================

model ServiceCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(120)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  image_url   String?  @db.VarChar(500)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  manufacturer_capabilities ManufacturerCapability[]
  rfq_projects              RfqProject[]

  @@map("service_categories")
}

model Company {
  id             Int         @id @default(autoincrement())
  name           String      @db.VarChar(200)
  slug           String      @unique @db.VarChar(220)
  type           CompanyType
  legal_id       String?     @db.VarChar(50)
  description    String?     @db.Text
  logo_url       String?     @db.VarChar(500)
  website        String?     @db.VarChar(500)
  phone          String?     @db.VarChar(50)
  email          String?     @db.VarChar(255)
  address_line1  String?     @db.VarChar(255)
  city           String?     @db.VarChar(100)
  state          String?     @db.VarChar(100)
  country        String      @default("Colombia") @db.VarChar(100)
  latitude       Decimal?    @db.Decimal(10, 8)
  longitude      Decimal?    @db.Decimal(11, 8)
  employee_count String?     @db.VarChar(10)
  founded_year   Int?        @db.SmallInt
  is_verified    Boolean     @default(false)
  is_active      Boolean     @default(true)
  verified_at    DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  users                          User[]
  manufacturer_capabilities      ManufacturerCapability[]
  manufacturer_certifications    ManufacturerCertification[]
  rfq_projects_as_brand          RfqProject[]             @relation("BrandCompany")
  proposals_as_manufacturer      Proposal[]               @relation("ManufacturerCompany")
  contracts_as_brand             Contract[]               @relation("ContractBrand")
  contracts_as_manufacturer      Contract[]               @relation("ContractManufacturer")
  conversations_as_brand         Conversation[]           @relation("ConvBrand")
  conversations_as_manufacturer  Conversation[]           @relation("ConvManufacturer")
  conversations_as_admin_target  Conversation[]           @relation("ConvAdminTarget")
  reviews_given                  Review[]                 @relation("ReviewerCompany")
  reviews_received               Review[]                 @relation("ReviewedCompany")
  payments_as_payer              Payment[]                @relation("Payer")
  payments_as_payee              Payment[]                @relation("Payee")

  @@map("companies")
}

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique @db.VarChar(255)
  password          String    @db.VarChar(255)
  first_name        String    @db.VarChar(100)
  last_name         String    @db.VarChar(100)
  phone             String?   @db.VarChar(50)
  avatar_url        String?   @db.VarChar(500)
  role              UserRole  @default(brand)
  company_id        Int?
  terms_accepted    Boolean   @default(false)
  email_verified    Boolean   @default(false)
  email_verified_at DateTime?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  company                    Company?       @relation(fields: [company_id], references: [id])
  addresses                  Address[]
  rfq_projects               RfqProject[]
  proposals                  Proposal[]
  messages                   Message[]
  reviews                    Review[]
  notifications              Notification[]
  initiated_conversations    Conversation[] @relation("ConversationInitiator")
  admin_conversations        Conversation[] @relation("ConversationAdmin")

  @@map("users")
}

model Address {
  id            Int      @id @default(autoincrement())
  user_id       Int
  label         String   @default("Oficina") @db.VarChar(100)
  address_line1 String   @db.VarChar(255)
  address_line2 String?  @db.VarChar(255)
  city          String   @db.VarChar(100)
  state         String?  @db.VarChar(100)
  postal_code   String?  @db.VarChar(20)
  country       String   @default("Colombia") @db.VarChar(100)
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model ManufacturerCapability {
  id                  Int      @id @default(autoincrement())
  company_id          Int
  category_id         Int
  min_order_qty       Int      @default(1)
  max_monthly_capacity Int?
  lead_time_days      Int?
  description         String?  @db.Text
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now())

  company             Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  category            ServiceCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([company_id, category_id])
  @@map("manufacturer_capabilities")
}

model ManufacturerCertification {
  id              Int      @id @default(autoincrement())
  company_id      Int
  name            String   @db.VarChar(100)
  issued_by       String?  @db.VarChar(200)
  certificate_url String?  @db.VarChar(500)
  issued_at       DateTime? @db.Date
  expires_at      DateTime? @db.Date
  is_verified     Boolean  @default(false)
  created_at      DateTime @default(now())

  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("manufacturer_certifications")
}

model RfqProject {
  id                   Int       @id @default(autoincrement())
  code                 String    @unique @db.VarChar(20)
  brand_company_id     Int
  created_by_user_id   Int
  category_id          Int
  title                String    @db.VarChar(255)
  description          String    @db.Text
  quantity             Int
  budget_min           Decimal?  @db.Decimal(12, 2)
  budget_max           Decimal?  @db.Decimal(12, 2)
  currency             String    @default("COP") @db.VarChar(3)
  deadline             DateTime? @db.Date
  proposals_deadline   DateTime? @db.Date
  status               RfqStatus @default(draft)
  requires_sample      Boolean   @default(false)
  preferred_materials  String?   @db.Text
  sustainability_priority Boolean @default(false)
  proposals_count      Int       @default(0)
  awarded_proposal_id  Int?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  brand_company        Company         @relation("BrandCompany", fields: [brand_company_id], references: [id])
  created_by           User            @relation(fields: [created_by_user_id], references: [id])
  category             ServiceCategory @relation(fields: [category_id], references: [id])
  awarded_proposal     Proposal?       @relation("AwardedProposal", fields: [awarded_proposal_id], references: [id])
  proposals            Proposal[]      @relation("RfqProposals")
  rfq_materials        RfqMaterial[]
  rfq_attachments      RfqAttachment[]
  conversations        Conversation[]
  contracts            Contract[]

  @@map("rfq_projects")
}

model RfqMaterial {
  id                   Int      @id @default(autoincrement())
  rfq_id               Int
  material_type        String   @db.VarChar(100)
  composition          String?  @db.VarChar(255)
  recycled_percentage  Int      @default(0) @db.TinyInt
  specifications       String?  @db.Text
  created_at           DateTime @default(now())

  rfq_project          RfqProject @relation(fields: [rfq_id], references: [id], onDelete: Cascade)

  @@map("rfq_materials")
}

model RfqAttachment {
  id          Int      @id @default(autoincrement())
  rfq_id      Int
  file_name   String   @db.VarChar(255)
  file_url    String   @db.VarChar(500)
  file_type   String?  @db.VarChar(50)
  file_size   Int?
  created_at  DateTime @default(now())

  rfq_project RfqProject @relation(fields: [rfq_id], references: [id], onDelete: Cascade)

  @@map("rfq_attachments")
}

model Proposal {
  id                      Int            @id @default(autoincrement())
  rfq_id                  Int
  manufacturer_company_id Int
  submitted_by_user_id    Int
  unit_price              Decimal        @db.Decimal(12, 2)
  total_price             Decimal        @db.Decimal(12, 2)
  currency                String         @default("COP") @db.VarChar(3)
  lead_time_days          Int
  proposed_materials      String?        @db.Text
  recycled_percentage     Int            @default(0) @db.TinyInt
  notes                   String?        @db.Text
  status                  ProposalStatus @default(submitted)
  green_score             Decimal        @default(0.00) @db.Decimal(5, 2)
  distance_km             Decimal?       @db.Decimal(8, 2)
  submitted_at            DateTime       @default(now())
  responded_at            DateTime?
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt

  rfq_project             RfqProject     @relation("RfqProposals", fields: [rfq_id], references: [id], onDelete: Cascade)
  manufacturer_company    Company        @relation("ManufacturerCompany", fields: [manufacturer_company_id], references: [id])
  submitted_by            User           @relation(fields: [submitted_by_user_id], references: [id])
  awarded_rfq_projects    RfqProject[]   @relation("AwardedProposal")
  contracts               Contract[]

  @@unique([rfq_id, manufacturer_company_id])
  @@map("proposals")
}

model Contract {
  id                      Int            @id @default(autoincrement())
  code                    String         @unique @db.VarChar(20)
  rfq_id                  Int
  proposal_id             Int
  brand_company_id        Int
  manufacturer_company_id Int
  total_amount            Decimal        @db.Decimal(12, 2)
  currency                String         @default("COP") @db.VarChar(3)
  status                  ContractStatus @default(active)
  terms                   String?        @db.Text
  start_date              DateTime?      @db.Date
  expected_end_date       DateTime?      @db.Date
  actual_end_date         DateTime?      @db.Date
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt

  rfq_project             RfqProject     @relation(fields: [rfq_id], references: [id])
  proposal                Proposal       @relation(fields: [proposal_id], references: [id])
  brand_company           Company        @relation("ContractBrand", fields: [brand_company_id], references: [id])
  manufacturer_company    Company        @relation("ContractManufacturer", fields: [manufacturer_company_id], references: [id])
  milestones              ContractMilestone[]
  conversations           Conversation[]
  reviews                 Review[]
  payments                Payment[]

  @@map("contracts")
}

model ContractMilestone {
  id              Int                    @id @default(autoincrement())
  contract_id     Int
  title           String                 @db.VarChar(200)
  description     String?                @db.Text
  sort_order      Int                    @default(0) @db.TinyInt
  status          MilestoneStatus        @default(pending)
  payment_amount  Decimal                @default(0.00) @db.Decimal(12, 2)
  payment_status  MilestonePaymentStatus @default(pending)
  due_date        DateTime?              @db.Date
  completed_at    DateTime?
  created_at      DateTime               @default(now())

  contract        Contract               @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@map("contract_milestones")
}

model Conversation {
  id                      Int                @id @default(autoincrement())
  rfq_id                  Int?
  contract_id             Int?
  brand_company_id        Int?
  manufacturer_company_id Int?
  target_company_id       Int?
  admin_user_id           Int?
  initiated_by_user_id    Int
  subject                 String?            @db.VarChar(255)
  status                  ConversationStatus @default(pending)
  last_message_at         DateTime?
  accepted_at             DateTime?
  created_at              DateTime           @default(now())

  rfq_project             RfqProject?        @relation(fields: [rfq_id], references: [id])
  contract                Contract?          @relation(fields: [contract_id], references: [id])
  brand_company           Company?           @relation("ConvBrand", fields: [brand_company_id], references: [id], onDelete: Cascade)
  manufacturer_company    Company?           @relation("ConvManufacturer", fields: [manufacturer_company_id], references: [id], onDelete: Cascade)
  target_company          Company?           @relation("ConvAdminTarget", fields: [target_company_id], references: [id], onDelete: Cascade)
  admin_user              User?              @relation("ConversationAdmin", fields: [admin_user_id], references: [id], onDelete: Cascade)
  initiated_by            User               @relation("ConversationInitiator", fields: [initiated_by_user_id], references: [id], onDelete: Cascade)
  messages                Message[]

  @@map("conversations")
}

model Message {
  id              Int         @id @default(autoincrement())
  conversation_id Int
  sender_user_id  Int
  content         String      @db.Text
  message_type    MessageType @default(text)
  file_url        String?     @db.VarChar(500)
  is_read         Boolean     @default(false)
  read_at         DateTime?
  created_at      DateTime    @default(now())

  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [sender_user_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Review {
  id                  Int      @id @default(autoincrement())
  contract_id         Int
  reviewer_company_id Int
  reviewed_company_id Int
  reviewer_user_id    Int
  rating              Int      @db.TinyInt
  comment             String?  @db.Text
  is_public           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  contract            Contract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  reviewer_company    Company  @relation("ReviewerCompany", fields: [reviewer_company_id], references: [id], onDelete: Cascade)
  reviewed_company    Company  @relation("ReviewedCompany", fields: [reviewed_company_id], references: [id], onDelete: Cascade)
  reviewer_user       User     @relation(fields: [reviewer_user_id], references: [id], onDelete: Cascade)

  @@unique([contract_id, reviewer_company_id])
  @@map("reviews")
}

model Payment {
  id               Int           @id @default(autoincrement())
  contract_id      Int
  milestone_id     Int?
  payer_company_id Int
  payee_company_id Int
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("COP") @db.VarChar(3)
  payment_method   PaymentMethod @default(transfer)
  status           PaymentStatus @default(pending)
  transaction_id   String?       @db.VarChar(255)
  payment_gateway  String?       @db.VarChar(50)
  paid_at          DateTime?
  refunded_at      DateTime?
  metadata         Json?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  contract         Contract          @relation(fields: [contract_id], references: [id])
  milestone        ContractMilestone? @relation(fields: [milestone_id], references: [id])
  payer_company    Company           @relation("Payer", fields: [payer_company_id], references: [id])
  payee_company    Company           @relation("Payee", fields: [payee_company_id], references: [id])

  @@map("payments")
}

model Notification {
  id             Int              @id @default(autoincrement())
  user_id        Int
  title          String           @db.VarChar(255)
  message        String           @db.Text
  type           NotificationType
  reference_type String?          @db.VarChar(50)
  reference_id   Int?
  is_read        Boolean          @default(false)
  read_at        DateTime?
  created_at     DateTime         @default(now())

  user           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}
